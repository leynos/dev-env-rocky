#!/usr/bin/env bash
# Installs configured sub-agent bootstrap blocks.

replace_managed_block() {
    local file marker block begin_sentinel end_sentinel tmp begin_count end_count
    local file_dir
    local first_begin first_end
    file="$1"
    marker="$2"
    block="$3"
    begin_sentinel="### BEGIN ${marker}"
    end_sentinel="### END ${marker}"
    file_dir="$(dirname "${file}")"

    mkdir -p "${file_dir}"
    tmp="$(mktemp "${file_dir}/.replace-managed-block.XXXXXX")" || return 1
    REPLACE_MANAGED_BLOCK_TMP="${tmp}"
    trap 'rm -f "${REPLACE_MANAGED_BLOCK_TMP:-}"' EXIT ERR
    touch "${file}"

    begin_count=$(grep -cF "${begin_sentinel}" "${file}" 2>/dev/null || true)
    end_count=$(grep -cF "${end_sentinel}" "${file}" 2>/dev/null || true)

    if [[ "${begin_count}" -ne "${end_count}" ]]; then
        printf 'replace_managed_block: unbalanced sentinels for %s in %s (%d BEGIN, %d END)\n' \
            "${marker}" "${file}" "${begin_count}" "${end_count}" >&2
        rm -f "${tmp}"
        return 1
    fi

    if [[ "${begin_count}" -gt 1 ]]; then
        printf 'replace_managed_block: duplicate managed blocks for %s in %s (%d BEGIN, %d END)\n' \
            "${marker}" "${file}" "${begin_count}" "${end_count}" >&2
        rm -f "${tmp}"
        return 1
    fi

    if [[ "${begin_count}" -eq 1 ]]; then
        first_begin=$(grep -nF "${begin_sentinel}" "${file}" | head -n1 | cut -d: -f1)
        first_end=$(grep -nF "${end_sentinel}" "${file}" | head -n1 | cut -d: -f1)
        if [[ "${first_end}" -lt "${first_begin}" ]]; then
            printf 'replace_managed_block: END sentinel appears before BEGIN for %s in %s\n' \
                "${marker}" "${file}" >&2
            rm -f "${tmp}"
            return 1
        fi
    fi

    if [[ "${begin_count}" -eq 0 ]]; then
        {
            cat "${file}"
            if [[ -s "${file}" ]]; then
                printf '\n'
            fi
            printf '%s\n' "${begin_sentinel}"
            printf '%s\n' "${block}"
            printf '%s\n' "${end_sentinel}"
        } >"${tmp}"
    else
        awk \
            -v begin="${begin_sentinel}" \
            -v end="${end_sentinel}" \
            -v replacement="${block}" '
            $0 == begin {
                print begin
                print replacement
                replacing = 1
                next
            }
            $0 == end && replacing {
                print end
                replacing = 0
                next
            }
            !replacing { print }
        ' "${file}" >"${tmp}"
    fi

    mv "${tmp}" "${file}"
}
