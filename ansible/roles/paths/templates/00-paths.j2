# ~/.bashrc.d/00-paths
# Generated by Ansible - do not edit manually

# pathmunge - Add directory to PATH if not already present
# Source: /etc/profile
pathmunge() {
    case ":${PATH}:" in
        *:"$1":*)
            ;;
        *)
            if [ "${2:-}" = "after" ]; then
                PATH=$PATH:$1
            else
                PATH=$1:$PATH
            fi
    esac
}

# Add development tool directories to PATH
for dir in \
    "${HOME}/.local/bin" \
    "${HOME}/.cargo/bin" \
    "${HOME}/.bun/bin" \
    "${HOME}/go/bin"
do
    if [ -d "$dir" ]; then
        pathmunge "$dir"
    fi
done

unset -f pathmunge

export PATH
