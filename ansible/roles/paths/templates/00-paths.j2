# ~/.bashrc.d/00-paths
# Generated by Ansible - do not edit manually

# Remove all occurrences of a managed directory before re-adding it once.
path_remove_managed() {
    managed_dir=$1
    old_ifs=$IFS
    new_path=

    IFS=:
    for path_entry in ${PATH:-}; do
        if [ -n "$path_entry" ] && [ "$path_entry" != "$managed_dir" ]; then
            if [ -n "$new_path" ]; then
                new_path=$new_path:$path_entry
            else
                new_path=$path_entry
            fi
        fi
    done
    IFS=$old_ifs

    PATH=$new_path
}

path_prepend_managed() {
    managed_dir=$1

    path_remove_managed "$managed_dir"

    if [ -d "$managed_dir" ]; then
        if [ -n "${PATH:-}" ]; then
            PATH=$managed_dir:$PATH
        else
            PATH=$managed_dir
        fi
    fi
}

# Add managed tool directories to PATH in reverse order. Each prepend removes
# stale copies first, leaving the documented visible order in the final PATH.
for dir in \
    "${HOME}/go/bin" \
    "${HOME}/.bun/bin" \
    "${HOME}/.cargo/bin" \
    "${HOME}/.local/bin"
do
    path_prepend_managed "$dir"
done

unset -f path_prepend_managed
unset -f path_remove_managed
unset dir managed_dir new_path old_ifs path_entry

export PATH
