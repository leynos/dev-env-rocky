#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "jinja2>=3.1.0",
# ]
# ///
"""
setup-paths - Generate ~/.bashrc.d/00-paths with PATH configuration.

This script templates a bash configuration file that:
  1. Defines the pathmunge function (from /etc/profile)
  2. Adds common development tool directories to PATH

The generated file is suitable for sourcing from ~/.bashrc via a
bashrc.d pattern.

Usage:
    setup-paths

Output:
    Writes to ~/.bashrc.d/00-paths (creates directory if needed)

Exit codes:
    0  File generated successfully
    1  Template error or write failure

Dependencies:
    - Python 3.11+
    - Jinja2
    - uv (for script execution)
"""
from pathlib import Path

from jinja2 import Template

TEMPLATE = """\
# {{ header }}
# Generated by setup-paths - do not edit manually

# pathmunge - Add directory to PATH if not already present
# Source: /etc/profile
pathmunge() {
    case ":${PATH}:" in
        *:"$1":*)
            ;;
        *)
            if [ "${2:-}" = "after" ]; then
                PATH=$PATH:$1
            else
                PATH=$1:$PATH
            fi
    esac
}

# Add development tool directories to PATH
for dir in \\
{%- for path in paths %}
    "{{ path }}"{{ " \\\\" if not loop.last else "" }}{% endfor %}
do
    if [ -d "$dir" ]; then
        pathmunge "$dir"
    fi
done

unset -f pathmunge

export PATH
"""

PATHS = [
    "${HOME}/.local/bin",
    "${HOME}/.cargo/bin",
    "${HOME}/.bun/bin",
    "${HOME}/go/bin",
]


def main() -> int:
    template = Template(TEMPLATE)
    content = template.render(
        header="~/.bashrc.d/00-paths",
        paths=PATHS,
    )

    bashrc_d = Path.home() / ".bashrc.d"
    bashrc_d.mkdir(parents=True, exist_ok=True)

    output_path = bashrc_d / "00-paths"
    output_path.write_text(content)

    print(f"Generated: {output_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
