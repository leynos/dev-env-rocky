#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "jinja2>=3.1.0",
# ]
# ///
"""
setup-paths - Generate ~/.bashrc.d/00-paths with PATH configuration.

This script templates a bash configuration file that:
  1. Defines helper functions for managed PATH entries
  2. Normalises common development tool directories into PATH

The generated file is suitable for sourcing from ~/.bashrc via a
bashrc.d pattern.

Usage:
    setup-paths

Output:
    Writes to ~/.bashrc.d/00-paths (creates directory if needed)

Exit codes:
    0  File generated successfully
    1  Template error or write failure

Dependencies:
    - Python 3.11+
    - Jinja2
    - uv (for script execution)
"""
from pathlib import Path

from jinja2 import Template

TEMPLATE = """\
# {{ header }}
# Generated by setup-paths - do not edit manually

# Remove all occurrences of a managed directory before re-adding it once.
path_remove_managed() {
    managed_dir=$1
    old_ifs=$IFS
    new_path=

    IFS=:
    for path_entry in ${PATH:-}; do
        if [ -n "$path_entry" ] && [ "$path_entry" != "$managed_dir" ]; then
            if [ -n "$new_path" ]; then
                new_path=$new_path:$path_entry
            else
                new_path=$path_entry
            fi
        fi
    done
    IFS=$old_ifs

    PATH=$new_path
}

path_prepend_managed() {
    managed_dir=$1

    path_remove_managed "$managed_dir"

    if [ -d "$managed_dir" ]; then
        if [ -n "${PATH:-}" ]; then
            PATH=$managed_dir:$PATH
        else
            PATH=$managed_dir
        fi
    fi
}

# Add managed tool directories to PATH in reverse order. Each prepend removes
# stale copies first, leaving the documented visible order in the final PATH.
for dir in \\
{%- for path in paths %}
    "{{ path }}"{{ " \\\\" if not loop.last else "" }}{% endfor %}
do
    path_prepend_managed "$dir"
done

unset -f path_prepend_managed
unset -f path_remove_managed
unset dir managed_dir new_path old_ifs path_entry

export PATH
"""

PATHS = [
    "${HOME}/go/bin",
    "${HOME}/.bun/bin",
    "${HOME}/.cargo/bin",
    "${HOME}/.local/bin",
]


def main() -> int:
    template = Template(TEMPLATE)
    content = template.render(
        header="~/.bashrc.d/00-paths",
        paths=PATHS,
    )

    bashrc_d = Path.home() / ".bashrc.d"
    bashrc_d.mkdir(parents=True, exist_ok=True)

    output_path = bashrc_d / "00-paths"
    output_path.write_text(content)

    print(f"Generated: {output_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
